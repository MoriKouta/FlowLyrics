<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="FlowLyrics.CandidateSearchWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Choose from LRCLIB" Width="860" Height="760" MinWidth="680" MinHeight="560" WindowStartupLocation="CenterOwner" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource Paper}" ShowInTaskbar="False" xmlns:flowlyrics="clr-namespace:FlowLyrics;assembly=FlowLyrics">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <SolidColorBrush x:Key="Orange" Color="#FFFF8A3D" />
      <SolidColorBrush x:Key="WindowBackground" Color="#FFE5E7E4" />
      <SolidColorBrush x:Key="Panel" Color="#FFF2F3F1" />
      <SolidColorBrush x:Key="Paper" Color="#FF202321" />
      <SolidColorBrush x:Key="Muted" Color="#FF404542" />
      <SolidColorBrush x:Key="Control" Color="#FFDCDFDC" />
      <SolidColorBrush x:Key="ControlBorder" Color="#FFAEB4AF" />
      <SolidColorBrush x:Key="Input" Color="#FFFAFAF8" />
      <FontFamily x:Key="DotFont">pack://application:,,,/Assets/Fonts/#Flow Dots, Segoe UI, Yu Gothic UI, Microsoft YaHei UI, Malgun Gothic</FontFamily>
      <FontFamily x:Key="EnglishDotFont">pack://application:,,,/Assets/Fonts/#Flow Dots, Segoe UI</FontFamily>
      <Style x:Key="{x:Type Button}" TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="{DynamicResource Paper}" />
        <Setter Property="Background" Value="{DynamicResource Control}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="Margin" Value="4" />
        <Setter Property="FontFamily" Value="{DynamicResource DotFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FrameworkElement.Cursor" Value="Hand" />
      </Style>
      <Style x:Key="{x:Type TextBox}" TargetType="{x:Type TextBox}">
        <Setter Property="Foreground" Value="{DynamicResource Paper}" />
        <Setter Property="Background" Value="{DynamicResource Input}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Orange}" />
        <Setter Property="Padding" Value="9,7" />
        <Setter Property="Margin" Value="4" />
      </Style>
      <Style x:Key="Label" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource EnglishDotFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource Muted}" />
        <Setter Property="Margin" Value="4,8,4,2" />
      </Style>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Border Grid.Row="0" Padding="16" CornerRadius="8" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource ControlBorder}" BorderThickness="1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Name="TitleLabel" Style="{StaticResource Label}" Text="Title" />
        <TextBox Name="TitleBox" Grid.Row="1" />
        <TextBlock Name="ArtistLabel" Grid.Column="1" Style="{StaticResource Label}" Text="Artist" />
        <TextBox Name="ArtistBox" Grid.Row="1" Grid.Column="1" />
        <TextBlock Name="AlbumLabel" Grid.Row="2" Style="{StaticResource Label}" Text="Album" />
        <TextBox Name="AlbumBox" Grid.Row="3" />
        <TextBlock Name="KeywordLabel" Grid.Row="2" Grid.Column="1" Style="{StaticResource Label}" Text="Keyword" />
        <TextBox Name="KeywordBox" Grid.Row="3" Grid.Column="1" />
      </Grid>
    </Border>
    <Grid Row="1" Margin="0,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Margin="0,0,12,0" VerticalAlignment="Center">
        <TextBlock Name="StatusText" VerticalAlignment="Center" Foreground="{DynamicResource Muted}" TextWrapping="Wrap" />
        <StackPanel Name="LoadingDotLine" Margin="0,8,0,0" HorizontalAlignment="Left" Orientation="Horizontal" Visibility="Collapsed">
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Margin="0,0,5,0" Fill="{DynamicResource Orange}" Opacity="0.14" />
          <Ellipse Width="4" Height="4" Fill="{DynamicResource Orange}" Opacity="0.14" />
        </StackPanel>
      </StackPanel>
      <Button Name="SearchButton" Grid.Column="1" Background="{DynamicResource Orange}" Foreground="#FF171717" BorderBrush="{DynamicResource Orange}" Content="Search LRCLIB" Click="Search_Click" />
    </Grid>
    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <ItemsControl Name="ResultsList">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,0,0,10" Padding="16" CornerRadius="8" Background="{DynamicResource Panel}" BorderThickness="2" BorderBrush="{Binding QualityBrush}">
              <StackPanel>
                <DockPanel>
                  <Border DockPanel.Dock="Right" Padding="8,4" CornerRadius="4" Background="{Binding QualityBrush}">
                    <TextBlock Foreground="#FF171717" FontWeight="Bold" Text="{Binding Quality}" />
                  </Border>
                  <StackPanel>
                    <TextBlock FontSize="18" FontWeight="Bold" TextWrapping="Wrap" Text="{Binding Title}" />
                    <TextBlock Margin="0,3,0,0" FontSize="14" TextWrapping="Wrap" Text="{Binding Artist}" />
                  </StackPanel>
                </DockPanel>
                <TextBlock Margin="0,7,0,0" Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Text="{Binding Album}" />
                <TextBlock Margin="0,6,0,0" FontFamily="{DynamicResource DotFont}" Foreground="{DynamicResource Orange}" TextWrapping="Wrap" Text="{Binding Summary}" />
                <TextBlock Margin="0,7,0,0" Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Text="{Binding Matches}" />
                <TextBlock Margin="0,3,0,0" Foreground="#FFFFB09A" TextWrapping="Wrap" Text="{Binding Mismatches}" />
                <TextBlock Margin="0,4,0,0" Foreground="#FFFFB09A" TextWrapping="Wrap" Text="{Binding DisabledReason}" />
                <WrapPanel Margin="-4,8,0,0">
                  <Button Content="{Binding PreviewLabel}" Tag="{Binding}" Click="Preview_Click" />
                  <Button Background="{DynamicResource Orange}" Foreground="#FF171717" BorderBrush="{DynamicResource Orange}" Content="{Binding UseLabel}" Tag="{Binding}" IsEnabled="{Binding CanUse}" Click="Use_Click" />
                  <Button Content="{Binding OpenLabel}" Tag="{Binding}" Click="Open_Click" />
                </WrapPanel>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
    <Button Name="CloseButton" Grid.Row="3" HorizontalAlignment="Right" Content="Close" IsCancel="True" Click="Close_Click" />
  </Grid>
</Window>
