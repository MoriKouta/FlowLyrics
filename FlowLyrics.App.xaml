<?xml version="1.0" encoding="utf-8"?>
<Application x:Class="FlowLyrics.App" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:flowlyrics="clr-namespace:FlowLyrics;assembly=FlowLyrics" ShutdownMode="OnExplicitShutdown">
  <Application.Resources>
    <ResourceDictionary>
      <SolidColorBrush x:Key="AccentBrush" Color="#FF7768EE" />
      <SolidColorBrush x:Key="PanelBrush" Color="#FF11141A" />
      <SolidColorBrush x:Key="PanelRaisedBrush" Color="#FF252A35" />
      <SolidColorBrush x:Key="TextBrush" Color="#FFF5F7FB" />
      <SolidColorBrush x:Key="MutedTextBrush" Color="#FF9BA3B3" />
      <Style x:Key="{x:Type Button}" TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
        <Setter Property="BorderBrush" Value="#FF3B3F4B" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="Margin" Value="4" />
        <Setter Property="FrameworkElement.Cursor" Value="Hand" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border Name="Surface" Padding="{TemplateBinding Control.Padding}" Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" CornerRadius="9">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter TargetName="Surface" Property="UIElement.Opacity" Value="0.84" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="Surface" Property="UIElement.Opacity" Value="0.62" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter TargetName="Surface" Property="UIElement.Opacity" Value="0.35" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="{x:Type TextBox}" TargetType="{x:Type TextBox}">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="Background" Value="#FF0E1117" />
        <Setter Property="BorderBrush" Value="#FF3A4150" />
        <Setter Property="Padding" Value="9,6" />
        <Setter Property="TextBoxBase.CaretBrush" Value="{StaticResource TextBrush}" />
      </Style>
      <Style x:Key="{x:Type ComboBox}" TargetType="{x:Type ComboBox}">
        <Setter Property="Foreground" Value="#FF15171C" />
        <Setter Property="Background" Value="#FFF4F4F5" />
        <Setter Property="Padding" Value="8,5" />
      </Style>
      <Style x:Key="{x:Type CheckBox}" TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="Margin" Value="0,5" />
      </Style>
    </ResourceDictionary>
  </Application.Resources>
</Application>