<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="FlowLyrics.LyricsPreviewWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Lyrics preview" Width="700" Height="700" MinWidth="560" MinHeight="480" WindowStartupLocation="CenterOwner" Background="#FF242424" Foreground="#FFF7F2EA" ShowInTaskbar="False" xmlns:flowlyrics="clr-namespace:FlowLyrics;assembly=FlowLyrics">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <SolidColorBrush x:Key="Orange" Color="#FFFF8A3D" />
      <FontFamily x:Key="DotFont">pack://application:,,,/Assets/Fonts/#Flow Dots, Segoe UI, Yu Gothic UI, Microsoft YaHei UI, Malgun Gothic</FontFamily>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Border Padding="18" CornerRadius="8" Background="#FF2F2F2F" BorderBrush="{DynamicResource Orange}" BorderThickness="1">
      <StackPanel>
        <TextBlock Name="TitleText" FontSize="24" FontWeight="Bold" TextWrapping="Wrap" />
        <TextBlock Name="ArtistText" Margin="0,7,0,0" FontSize="17" TextWrapping="Wrap" />
        <TextBlock Name="AlbumText" Margin="0,5,0,0" FontSize="14" Foreground="#FFD0CAC1" TextWrapping="Wrap" />
        <TextBlock Name="DurationText" Margin="0,9,0,0" FontFamily="{DynamicResource DotFont}" Foreground="{DynamicResource Orange}" TextWrapping="Wrap" />
      </StackPanel>
    </Border>
    <TextBox Name="LyricsText" Grid.Row="1" Margin="0,14,0,10" Padding="14" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="#FF171717" Foreground="#FFF7F2EA" BorderBrush="#FF393939" />
    <Button Name="CloseButton" Grid.Row="2" HorizontalAlignment="Right" Padding="16,8" Background="#FF393939" Foreground="#FFF7F2EA" BorderBrush="{DynamicResource Orange}" Content="Close" IsCancel="True" Click="Close_Click" />
  </Grid>
</Window>